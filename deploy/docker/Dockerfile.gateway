# syntax=docker/dockerfile:1
FROM golang:1.22 AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/gateway ./cmd/gateway-api

FROM alpine:3.19
WORKDIR /app
COPY --from=builder /out/gateway /app/gateway
EXPOSE 8080
CMD ["/app/gateway"]
