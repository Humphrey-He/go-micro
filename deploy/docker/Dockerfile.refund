# syntax=docker/dockerfile:1
FROM golang:1.25 AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/refund ./cmd/refund-service

FROM alpine:3.19
WORKDIR /app
COPY --from=builder /out/refund /app/refund
EXPOSE 8086 9086
CMD ["/app/refund"]
