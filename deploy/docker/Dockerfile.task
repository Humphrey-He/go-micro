# syntax=docker/dockerfile:1
FROM golang:1.22 AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/task ./cmd/task-service

FROM alpine:3.19
WORKDIR /app
COPY --from=builder /out/task /app/task
EXPOSE 8084
CMD ["/app/task"]
